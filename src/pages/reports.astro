---
import BaseLayout from "../layouts/BaseLayout.astro";
import reportData from "../data/report-templates.json";
import reportOptions from "../data/report-options.json";
import reportSections from "../data/report-sections.json";

const { categories, templates } = reportData;

const catMap = new Map<string, number>();
for (const t of templates) {
  catMap.set(t.category, (catMap.get(t.category) || 0) + 1);
}
const catList = categories
  .filter((c: string) => c !== '전체' && catMap.has(c))
  .map((name: string) => ({ name, count: catMap.get(name)! }));
---

<BaseLayout title="NotebookLM 보고서 스타일 빌더" currentPath="/reports">
  <section class="hero">
    <h1>보고서 스타일 빌더</h1>
    <p class="muted">{templates.length}개 템플릿 · 5가지 커스텀 옵션 · 복사해서 바로 사용</p>
  </section>

  <!-- Search -->
  <div class="tpl-search-wrap">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input type="text" id="rpt-search" placeholder="보고서 검색..." />
  </div>

  <!-- Filters -->
  <div class="tpl-filters">
    <button class="tpl-filter-btn active" data-cat="전체">전체 {templates.length}</button>
    {catList.map((c) => (
      <button class="tpl-filter-btn" data-cat={c.name}>{c.name} {c.count}</button>
    ))}
  </div>

  <!-- Grid -->
  <div class="rpt-grid" id="rpt-grid">
    {templates.map((t) => (
      <article
        class="rpt-card"
        data-id={t.id}
        data-category={t.category}
        data-name={t.name}
        data-desc={t.desc}
        data-icon={t.icon}
        data-defaults={JSON.stringify({structure:t.defaultStructure,tone:t.defaultTone,depth:t.defaultDepth,style:t.defaultStyle,audience:t.defaultAudience})}
        data-sections={JSON.stringify(t.sections)}
      >
        <div class="rpt-card-icon">{t.icon}</div>
        <div class="rpt-card-body">
          <h3>{t.name}</h3>
          <p>{t.desc}</p>
          <span class="rpt-card-cat">{t.category}</span>
        </div>
      </article>
    ))}
  </div>

  <!-- Modal -->
  <div class="tpl-modal-overlay" id="rpt-modal-overlay">
    <div class="tpl-modal rpt-modal">
      <div class="tpl-modal-header">
        <div>
          <h2 id="rpt-modal-title"></h2>
          <span class="muted" id="rpt-modal-desc"></span>
        </div>
        <button class="tpl-modal-close" id="rpt-close" aria-label="닫기">&times;</button>
      </div>

      <!-- Tabs -->
      <div class="tpl-modal-tabs">
        <button class="tpl-modal-tab active" data-rtab="options">커스텀 옵션</button>
        <button class="tpl-modal-tab" data-rtab="prompt">프롬프트 미리보기</button>
      </div>

      <!-- Tab 1: Custom Options -->
      <div class="rpt-tab-content active" id="rtab-options">
        <div class="rpt-options">
          <div class="rpt-opt-group">
            <div class="rpt-opt-label">구조</div>
            <div class="rpt-opt-btns" id="opt-structure"></div>
          </div>
          <div class="rpt-opt-group">
            <div class="rpt-opt-label">톤/어조</div>
            <div class="rpt-opt-btns" id="opt-tone"></div>
          </div>
          <div class="rpt-opt-group">
            <div class="rpt-opt-label">분량/깊이</div>
            <div class="rpt-opt-btns" id="opt-depth"></div>
          </div>
          <div class="rpt-opt-group">
            <div class="rpt-opt-label">서술 방식</div>
            <div class="rpt-opt-btns" id="opt-style"></div>
          </div>
          <div class="rpt-opt-group">
            <div class="rpt-opt-label">타겟 독자</div>
            <div class="rpt-opt-btns" id="opt-audience"></div>
          </div>
        </div>

        <div class="rpt-sections-preview" id="rpt-sections-preview"></div>

        <div class="rpt-nav">
          <span></span>
          <button class="rpt-gen-btn" id="rpt-gen-prompt">프롬프트 생성</button>
        </div>
      </div>

      <!-- Tab 2: Prompt Preview -->
      <div class="rpt-tab-content" id="rtab-prompt">
        <pre class="tpl-modal-prompt" id="rpt-prompt-text" style="max-height:60vh"></pre>
        <div class="rpt-nav">
          <button class="rpt-back-btn" id="rpt-back-opts">옵션 수정</button>
          <button class="rpt-gen-btn" id="rpt-copy-prompt">프롬프트 복사</button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ reportOptions, reportSections }}>
  const OPTIONS = reportOptions;
  const SUMMARY_SECTIONS = reportSections.summary;
  const STANDARD_SECTIONS = reportSections.standard;

  let currentTemplate = null;
  let currentOpts = {};

  const overlay = document.getElementById('rpt-modal-overlay');
  const grid = document.getElementById('rpt-grid');

  // ─── Filter & Search ───────────────────────────────────────────────
  const filterBtns = document.querySelectorAll('.tpl-filter-btn');
  const searchInput = document.getElementById('rpt-search');
  let activeCat = '전체';

  function filterCards() {
    const q = searchInput.value.trim().toLowerCase();
    const cards = grid.querySelectorAll('.rpt-card');
    cards.forEach(c => {
      const cat = c.dataset.category;
      const name = c.dataset.name.toLowerCase();
      const desc = c.dataset.desc.toLowerCase();
      const matchCat = activeCat === '전체' || cat === activeCat;
      const matchQ = !q || name.includes(q) || desc.includes(q);
      c.style.display = matchCat && matchQ ? '' : 'none';
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.dataset.cat;
      filterCards();
    });
  });
  searchInput.addEventListener('input', filterCards);

  // ─── Card Click → Open Modal ──────────────────────────────────────
  grid.addEventListener('click', (e) => {
    const card = e.target.closest('.rpt-card');
    if (!card) return;

    currentTemplate = {
      id: card.dataset.id,
      name: card.dataset.name,
      desc: card.dataset.desc,
      icon: card.dataset.icon,
      sections: JSON.parse(card.dataset.sections),
    };
    const defaults = JSON.parse(card.dataset.defaults);
    currentOpts = { ...defaults };

    document.getElementById('rpt-modal-title').textContent = currentTemplate.icon + ' ' + currentTemplate.name;
    document.getElementById('rpt-modal-desc').textContent = currentTemplate.desc;

    renderOptions();
    renderSectionsPreview();
    showTab('options');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  // ─── Close Modal ──────────────────────────────────────────────────
  function closeModal() { overlay.classList.remove('open'); document.body.style.overflow = ''; }
  document.getElementById('rpt-close').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ─── Tab Switching ────────────────────────────────────────────────
  const tabBtns = document.querySelectorAll('[data-rtab]');
  function showTab(name) {
    tabBtns.forEach(b => b.classList.toggle('active', b.dataset.rtab === name));
    document.getElementById('rtab-options').classList.toggle('active', name === 'options');
    document.getElementById('rtab-prompt').classList.toggle('active', name === 'prompt');
  }
  tabBtns.forEach(b => b.addEventListener('click', () => {
    showTab(b.dataset.rtab);
    if (b.dataset.rtab === 'prompt') renderPrompt();
  }));

  // ─── Render Option Buttons ────────────────────────────────────────
  function renderOptions() {
    const groups = ['structure', 'tone', 'depth', 'style', 'audience'];
    groups.forEach(group => {
      const container = document.getElementById('opt-' + group);
      container.innerHTML = '';
      OPTIONS[group].forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'rpt-opt-btn' + (currentOpts[group] === opt.id ? ' active' : '');
        btn.innerHTML = '<strong>' + opt.name + '</strong><span>' + opt.desc + '</span>';
        btn.addEventListener('click', () => {
          currentOpts[group] = opt.id;
          container.querySelectorAll('.rpt-opt-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          renderSectionsPreview();
        });
        container.appendChild(btn);
      });
    });
  }

  // ─── Sections Preview ─────────────────────────────────────────────
  function renderSectionsPreview() {
    const el = document.getElementById('rpt-sections-preview');
    const tid = currentTemplate.id;
    let sections;
    if (currentOpts.depth === 'summary') {
      sections = SUMMARY_SECTIONS[tid] || ['현황/배경', '핵심 분석', '결론/제언'];
    } else if (currentOpts.depth === 'standard') {
      sections = STANDARD_SECTIONS[tid] || currentTemplate.sections.slice(0, 5);
    } else {
      sections = currentTemplate.sections;
    }
    el.innerHTML = '<div class="rpt-opt-label" style="margin-bottom:8px">보고서 섹션 구성</div>' +
      sections.map((s, i) => '<div class="rpt-section-item">제' + (i + 1) + '장 ' + s + '</div>').join('');
  }

  // ─── Generate Prompt ──────────────────────────────────────────────
  document.getElementById('rpt-gen-prompt').addEventListener('click', () => {
    showTab('prompt');
    renderPrompt();
  });
  document.getElementById('rpt-back-opts').addEventListener('click', () => showTab('options'));

  // ─── Rules ────────────────────────────────────────────────────────
  const toneRules = {
    assertive: '• "~로 보인다", "~일 수 있다" 같은 추측 표현을 사용하지 마세요. "~이다", "~해야 한다"로 단정하세요.',
    neutral: '• "~로 분석된다", "~로 나타났다" 등 객관적 표현을 사용하세요. 개인 의견이나 주관적 판단은 배제하세요.',
    persuasive: '• 데이터 근거를 먼저 제시한 뒤 "따라서 ~해야 한다", "~가 필요하다"로 행동을 유도하세요.',
    casual: '• 전문 용어를 쉽게 풀어쓰되, 비즈니스 문서로서의 전문성은 유지하세요. 복잡한 개념은 비유나 예시로 설명하세요. 지나치게 구어체("~거든요", "~잖아요")는 피하세요.',
  };

  const structureRules = {
    pyramid: '• 첫 문단에 핵심 결론을 1~2문장으로 먼저 제시하고, 이후 근거를 중요도 순으로 배치하세요',
    timeline: '• 시기별 소제목(예: 2023년, 2024년, 2025~2026년)을 명확히 구분하고, 각 시기의 변화 포인트를 수치와 함께 제시하세요',
    problem: '• 「문제 정의」→「원인 분석」→「해결안 제시」 순서를 반드시 지키세요. 각 단계 전환이 명확하게 드러나도록 서술하세요',
    mece: '• 분류 기준을 먼저 명시하고, 항목 간 겹침이 없는지 확인하세요. 각 분류 항목은 동일한 깊이로 서술하세요',
    compare: '• 비교 대상의 항목별 차이를 반드시 비교표로 정리하세요. 표는 반드시 아래와 같은 격자형 형식을 사용하세요:\n| 비교 항목 | A제품 | B제품 |\n|---|---|---|\n| 항목1 | 값 | 값 |\n스타일 설정과 관계없이 핵심 비교 데이터는 이 형식의 표로 먼저 제시한 뒤, 해석과 시사점을 덧붙이세요',
  };

  const audienceRules = {
    executive: '• 각 섹션의 첫 문장에 결론을 배치하세요\n• 핵심 수치는 「괄호」로 감싸서 눈에 띄게 하세요\n• 배경 설명은 최소화하고 의사결정에 필요한 정보만 포함하세요',
    manager: '• 각 섹션 끝에 "액션 아이템" 또는 "팀 차원 시사점"을 명시하세요\n• 실행 가능한 수준의 구체적 제안을 포함하세요\n• 상위 보고 시 활용할 수 있는 핵심 문장을 포함하세요',
    worker: '• 단계별 프로세스는 번호를 매겨 정리하세요\n• 바로 적용 가능한 구체적 방법론과 도구를 명시하세요\n• 실무 활용 예시를 포함하세요',
    general: '• 전문 용어가 나오면 괄호 안에 쉬운 설명을 추가하세요\n• 비유와 일상적 예시를 적극 활용하세요\n• 숫자는 "약 ~" 형태로 쉽게 표현하세요',
  };

  function renderPrompt() {
    const t = currentTemplate;
    const opts = currentOpts;
    const struct = OPTIONS.structure.find(s => s.id === opts.structure);
    const tone = OPTIONS.tone.find(s => s.id === opts.tone);
    const depth = OPTIONS.depth.find(s => s.id === opts.depth);
    const style = OPTIONS.style.find(s => s.id === opts.style);
    const audience = OPTIONS.audience.find(s => s.id === opts.audience);

    let sectionsText;
    if (opts.depth === 'summary') {
      const ss = SUMMARY_SECTIONS[t.id] || ['현황/배경', '핵심 분석', '결론/제언'];
      sectionsText = '다음 3개 섹션으로 작성하세요:\n' + ss.map((s, i) => '제' + (i + 1) + '장 ' + s).join('\n') +
        '\n(원래 섹션 참고: ' + t.sections.join(', ') + ')';
    } else if (opts.depth === 'standard') {
      const st = STANDARD_SECTIONS[t.id] || t.sections.slice(0, 5);
      sectionsText = '다음 5개 섹션으로 작성하세요:\n' + st.map((s, i) => '제' + (i + 1) + '장 ' + s).join('\n') +
        '\n(원래 섹션 참고: ' + t.sections.join(', ') + ')';
    } else {
      sectionsText = '다음 섹션 순서를 따르세요:\n' + t.sections.map((s, i) => '제' + (i + 1) + '장 ' + s).join('\n');
    }

    const prompt = `[NotebookLM 보고서 생성 요청]

■ 보고서 유형: ${t.name}
■ 설명: ${t.desc}

━━━━━━━━━━━━━━━━━━━━━━

[역할]
이 노트북의 소스를 기반으로, 전문 비즈니스 리서치 애널리스트로서 보고서를 작성하세요.

[보고서 구조]
구조 방식: ${struct.name}
${struct.desc}
${structureRules[opts.structure] || ''}

${sectionsText}

[톤/어조]
${tone.name}: ${tone.desc}
${toneRules[opts.tone]}

[분량/깊이]
${depth.prompt}

[서술 방식]
${style.name}: ${style.desc}

[타겟 독자]
${audience.name}: ${audience.desc}

━━━━━━━━━━━━━━━━━━━━━━

[작성 규칙 - 공통]
• 모든 주장에 소스의 구체적 수치나 데이터를 근거로 제시하세요
• 소스에 없는 내용은 추가하지 마세요
• "다양한", "여러 가지" 같은 모호한 표현 대신 구체적 수치와 사례를 사용하세요
• 각 섹션의 끝에 핵심 시사점 1문장을 포함하세요
• 텍스트에 **별표 볼드**나 *별표 이태릭* 같은 마크다운 인라인 서식 기호를 쓰지 마세요. 강조가 필요하면 「괄호」나 문장 구조로 표현하세요. 단, 불릿 목록(•, -)과 표는 자유롭게 사용하세요

[작성 규칙 - 독자 맞춤]
${audienceRules[opts.audience]}

위 가이드를 바탕으로 소스 자료를 분석하여 고품질 보고서를 생성해주세요.`;

    document.getElementById('rpt-prompt-text').textContent = prompt;
  }

  // ─── Copy Prompt ──────────────────────────────────────────────────
  document.getElementById('rpt-copy-prompt').addEventListener('click', () => {
    const text = document.getElementById('rpt-prompt-text').textContent;
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('rpt-copy-prompt');
      const orig = btn.textContent;
      btn.textContent = '복사 완료!';
      btn.style.background = 'var(--beginner)';
      setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 1500);
    });
  });
</script>
