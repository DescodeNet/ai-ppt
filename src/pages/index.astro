---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import LevelBadge from "../components/LevelBadge.astro";
import { sortLessons } from "../lib/course";

const lessons = sortLessons(await getCollection("lessons"));
const firstByLevel = {
  beginner: lessons.find((lesson) => lesson.data.level === "beginner"),
  intermediate: lessons.find((lesson) => lesson.data.level === "intermediate"),
  advanced: lessons.find((lesson) => lesson.data.level === "advanced")
};
---

<BaseLayout title="메트라이프 2026 AI PPT 강의" currentPath="/">
  <section class="hero">
    <h1>메트라이프 2026 AI PPT 강의</h1>
    <p class="muted">
      강의 중 바로 열어 프롬프트를 복사하고 실습할 수 있도록 구성한 사이트입니다.
    </p>
  </section>

  <h2 class="section-title">트랙 시작점</h2>
  <div class="card-grid">
    {
      Object.entries(firstByLevel).map(([level, lesson]) =>
        lesson ? (
          <article class="card">
            <LevelBadge level={level as "beginner" | "intermediate" | "advanced"} />
            <h3 style="margin-top:0.5rem;">{lesson.data.title}</h3>
            <p class="muted">{lesson.data.summary}</p>
            <a href={`/lessons/${lesson.slug}`}>첫 레슨 열기</a>
          </article>
        ) : null
      )
    }
  </div>

  <h2 class="section-title">빠른 이동</h2>
  <div class="card-grid">
    <article class="card">
      <h3>강의 목록</h3>
      <p class="muted">초급/중급/고급 레슨을 난이도 순서대로 탐색합니다.</p>
      <a href="/lessons">강의 보기</a>
    </article>
    <article class="card">
      <h3>프롬프트 라이브러리</h3>
      <p class="muted">도구, 레벨, 주제 태그로 필요한 프롬프트만 빠르게 찾습니다.</p>
      <a href="/prompts">프롬프트 보기</a>
    </article>
    <article class="card">
      <h3>리소스</h3>
      <p class="muted">실습에 필요한 도구 링크를 모아 제공합니다.</p>
      <a href="/resources">리소스 보기</a>
    </article>
  </div>
</BaseLayout>
