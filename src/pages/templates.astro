  // ── Wizard state ──────────────────────────────────────────────────────────
  let currentStep = 1;
  let selectedWorkflow = '';
  let combinedPrompt = '';
  let sourcePrompt = '';

  function resetWizard() {
    currentStep = 1;
    selectedWorkflow = '';
    combinedPrompt = '';
    sourcePrompt = '';
    showStep(1);
    renderTypeButtons();
  }

  function showStep(step: number) {
    currentStep = step;
    for (let i = 1; i <= 5; i++) {
      const panel = document.getElementById(`wf-step${i}`);
      if (panel) panel.style.display = i === step ? '' : 'none';
    }
    document.querySelectorAll<HTMLElement>('.wf-step').forEach((el) => {
      const s = parseInt(el.dataset.step || '0');
      el.classList.remove('active', 'completed');
      if (s === step) el.classList.add('active');
      else if (s < step) el.classList.add('completed');
    });
  }

  // ── Step 1: type buttons ──────────────────────────────────────────────────
  function renderTypeButtons() {
    const container = document.getElementById('wf-types')!;
    const order = ['weekly', 'training', 'recruiting', 'proposal', 'morning', 'monthly'];
    container.innerHTML = order.map((key) => {
      const wf = workflows[key];
      return `<button class="wf-type-btn" data-wf="${key}">
        <span class="wf-type-icon">${wf.icon}</span>
        <span class="wf-type-name">${wf.name}</span>
      </button>`;
    }).join('');

    container.querySelectorAll<HTMLButtonElement>('.wf-type-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedWorkflow = btn.dataset.wf || '';
        renderFormStep();
        showStep(2);
      });
    });
  }

  // ── Step 2: form ──────────────────────────────────────────────────────────
  function renderFormStep() {
    const wf = workflows[selectedWorkflow];
    if (!wf) return;
    const titleEl = document.getElementById('wf-form-title')!;
    titleEl.textContent = `${wf.icon} ${wf.name} — 내용을 채워주세요`;

    const formEl = document.getElementById('wf-form')!;
    formEl.innerHTML = wf.fields.map((field) => {
      const isTextarea = field.type === 'textarea';
      const inputHtml = isTextarea
        ? `<textarea id="wf-field-${field.id}" placeholder="${field.placeholder}"></textarea>`
        : `<input type="text" id="wf-field-${field.id}" placeholder="${field.placeholder}" />`;
      return `<div class="wf-field">
        <label for="wf-field-${field.id}">${field.label}</label>
        ${inputHtml}
      </div>`;
    }).join('');
  }

  // ── Step 3: source prompt ─────────────────────────────────────────────────
  function buildSourcePrompt(): string {
    const wf = workflows[selectedWorkflow];
    if (!wf) return '';
    let filled = wf.sourceTemplate;
    wf.fields.forEach((field) => {
      const el = document.getElementById(`wf-field-${field.id}`) as HTMLInputElement | HTMLTextAreaElement | null;
      const val = el?.value.trim() || el?.getAttribute('placeholder') || '';
      filled = filled.split(`{{${field.id}}}`).join(val);
    });
    return filled;
  }

  function renderSourceStep() {
    sourcePrompt = buildSourcePrompt();
    const preview = document.getElementById('wf-source-prompt')!;
    preview.textContent = sourcePrompt;
  }

  // ── Step 4: combined prompt ───────────────────────────────────────────────
  function buildCombinedPrompt(): string {
    const wf = workflows[selectedWorkflow];
    if (!wf) return '';

    let filled = wf.template;
    wf.fields.forEach((field) => {
      const el = document.getElementById(`wf-field-${field.id}`) as HTMLInputElement | HTMLTextAreaElement | null;
      const val = el?.value.trim() || el?.getAttribute('placeholder') || '';
      filled = filled.split(`{{${field.id}}}`).join(val);
    });

    return `[디자인 스타일: ${currentTemplateName}]\n${currentPrompt}\n\n━━━━━━━━━━━━━━━━━━━━━━\n\n[업무: ${wf.name}]\n${filled}`;
  }

  function renderPromptPreview() {
    combinedPrompt = buildCombinedPrompt();
    const preview = document.getElementById('wf-prompt-preview')!;
    preview.textContent = combinedPrompt;
  }

  // ── Step navigation wiring ────────────────────────────────────────────────
  document.getElementById('wf-back2')!.addEventListener('click', () => showStep(1));
  document.getElementById('wf-next2')!.addEventListener('click', () => {
    renderSourceStep();
    showStep(3);
  });

  document.getElementById('wf-back3')!.addEventListener('click', () => showStep(2));
  document.getElementById('wf-copy-source')!.addEventListener('click', async () => {
    const btn = document.getElementById('wf-copy-source') as HTMLButtonElement;
    await navigator.clipboard.writeText(sourcePrompt);
    btn.textContent = '복사됨!';
    setTimeout(() => { btn.textContent = '소스 프롬프트 복사'; }, 2000);
  });
  document.getElementById('wf-next3')!.addEventListener('click', () => {
    renderPromptPreview();
    showStep(4);
  });

  document.getElementById('wf-back4')!.addEventListener('click', () => showStep(3));
  document.getElementById('wf-copy4')!.addEventListener('click', async () => {
    const btn = document.getElementById('wf-copy4') as HTMLButtonElement;
    await navigator.clipboard.writeText(combinedPrompt);
    btn.textContent = '복사됨!';
    setTimeout(() => { btn.textContent = '프롬프트 복사'; }, 2000);
  });
  document.getElementById('wf-next4')!.addEventListener('click', () => showStep(5));

  document.getElementById('wf-back5')!.addEventListener('click', () => showStep(4));
  document.getElementById('wf-done')!.addEventListener('click', () => modal.classList.remove('open'));
</script>
